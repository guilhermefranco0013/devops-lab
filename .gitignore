# =========================================================
# ENVIRONMENT VARIABLES / SECRETS
# =========================================================

.env
.env.*
!.env.example

env/
secrets/

# =========================================================
# TLS / SSL CERTIFICATES
# NEVER COMMIT PRIVATE KEYS
# =========================================================

*.key
*.pem
*.p12
*.pfx
*.csr
*.crt
*.cer

!*.example.crt
!*.example.key

nginx/certs/*
!nginx/certs/.gitkeep
!nginx/certs/README.md

